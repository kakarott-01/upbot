{
  "name": "upbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "mode-audit:dry-run": "node scripts/clean_mode_audit.js",
    "mode-audit:run": "node scripts/clean_mode_audit.js --run",
    "mode-audit:check-localstorage-guard": "node -e \"const fs=require('fs'); const pathA='lib/local-storage.ts'; const pathB='lib/bot-sync.ts'; try{ const s=fs.readFileSync(pathA,'utf8'); if(!/export\\s+function\\s+safeLocalSet/.test(s)){console.error('safeLocalSet not exported in '+pathA); process.exit(2);} const b=fs.readFileSync(pathB,'utf8'); if(!/safeLocalSet/.test(b)){console.error(pathB+' does not reference safeLocalSet'); process.exit(2);} console.log('local-storage:ok'); }catch(e){ console.error('local-storage check failed', e); process.exit(2);}\"",
    "ci:mode-audit-retention": "npm run mode-audit:check-localstorage-guard && npm run mode-audit:run"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
