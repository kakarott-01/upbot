    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.11",
    "@upstash/redis": "^1.32.0",
    "autoprefixer": "^10.0.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.22.7",
    "drizzle-orm": "^0.31.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.400.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.7",
    "postcss": "^8",
    "postgres": "^3.4.8",
